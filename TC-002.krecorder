<tr><td>type</td><td>id=id_shortname<datalist><option>id=id_shortname</option></datalist></td><td>sn033_ssssssss</td></tr>
<tr><td>runScript</td><td>var cb=document.getElementById('id_enddate_enabled');if(cb&&cb.checked){cb.click();}<datalist><option>var cb=document.getElementById('id_enddate_enabled');if(cb&&cb.checked){cb.click();}</option></datalist></td><td></td></tr>
<tr><td>runScript</td><td>var e=document.getElementById('id_numsections');if(e){e.value='10';e.dispatchEvent(new Event('change',{bubbles:true}));}<datalist><option>var e=document.getElementById('id_numsections');if(e){e.value='10';e.dispatchEvent(new Event('change',{bubbles:true}));}</option></datalist></td><td></td></tr>
