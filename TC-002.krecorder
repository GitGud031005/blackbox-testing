<tr><td>runScript</td><td>var end=new Date();end.setFullYear(end.getFullYear()+(0));end.setMonth(end.getMonth()+(0));end.setDate(end.getDate()+(-1));function sS(id,v){var e=document.getElementById(id);if(e){e.value=String(v);e.dispatchEvent(new Event('change',{bubbles:true}));}}sS('id_enddate_day',end.getDate());sS('id_enddate_month',end.getMonth()+1);sS('id_enddate_year',end.getFullYear());sS('id_enddate_hour',end.getHours());sS('id_enddate_minute',end.getMinutes());<datalist><option>var end=new Date();end.setFullYear(end.getFullYear()+(0));end.setMonth(end.getMonth()+(0));end.setDate(end.getDate()+(-1));function sS(id,v){var e=document.getElementById(id);if(e){e.value=String(v);e.dispatchEvent(new Event('change',{bubbles:true}));}}sS('id_enddate_day',end.getDate());sS('id_enddate_month',end.getMonth()+1);sS('id_enddate_year',end.getFullYear());sS('id_enddate_hour',end.getHours());sS('id_enddate_minute',end.getMinutes());</option></datalist></td><td></td></tr>
