<tr><td>type</td><td>id=id_shortname<datalist><option>id=id_shortname</option></datalist></td><td>TC001</td></tr>
<tr><td>runScript</td><td>var end=new Date();end.setFullYear(end.getFullYear()+(0));end.setMonth(end.getMonth()+(0));end.setDate(end.getDate()+(30));function sS(id,v){var e=document.getElementById(id);if(e){e.value=String(v);e.dispatchEvent(new Event('change',{bubbles:true}));}}sS('id_enddate_day',end.getDate());sS('id_enddate_month',end.getMonth()+1);sS('id_enddate_year',end.getFullYear());sS('id_enddate_hour',end.getHours());sS('id_enddate_minute',end.getMinutes());<datalist><option>var end=new Date();end.setFullYear(end.getFullYear()+(0));end.setMonth(end.getMonth()+(0));end.setDate(end.getDate()+(30));function sS(id,v){var e=document.getElementById(id);if(e){e.value=String(v);e.dispatchEvent(new Event('change',{bubbles:true}));}}sS('id_enddate_day',end.getDate());sS('id_enddate_month',end.getMonth()+1);sS('id_enddate_year',end.getFullYear());sS('id_enddate_hour',end.getHours());sS('id_enddate_minute',end.getMinutes());</option></datalist></td><td></td></tr>
<tr><td>runScript</td><td>var e=document.getElementById('id_numsections');if(e){e.value='10';e.dispatchEvent(new Event('change',{bubbles:true}));}<datalist><option>var e=document.getElementById('id_numsections');if(e){e.value='10';e.dispatchEvent(new Event('change',{bubbles:true}));}</option></datalist></td><td></td></tr>
<tr><td>click</td><td>id=id_saveanddisplay<datalist><option>id=id_saveanddisplay</option></datalist></td><td></td></tr>
<tr><td>verifyElementPresent</td><td>css=[id^="id_error_"]<datalist><option>css=[id^="id_error_"]</option></datalist></td><td></td></tr>
</tbody></table>
